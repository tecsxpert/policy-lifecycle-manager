# =============================================================================
# Policy Lifecycle Manager — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit `.env` to Git — it is listed in `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=policydb
POSTGRES_USER=policyuser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Python AI Service
# -----------------------------------------------------------------------------
AI_PORT=5000

# -----------------------------------------------------------------------------
# Spring Boot Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=8080

# JWT Secret — must be at least 256 bits (32 bytes) for HS256.
# Generate a secure key with: openssl rand -base64 32
JWT_SECRET=your_256_bit_secret_key_here_change_me

# -----------------------------------------------------------------------------
# React Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=80

